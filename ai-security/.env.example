# ============================================================
# Environment variables untuk AI Risk Detection Service
# Salin file ini ke .env dan isi semua nilai yang kosong.
# JANGAN commit file .env ke version control.
# ============================================================

# Kunci rahasia untuk autentikasi API dari Laravel
# Gunakan string acak minimal 32 karakter
API_KEY=change-this-to-a-long-random-secret-string

# Environment: production | development
APP_ENV=production

# Threshold keputusan risiko (opsional — ada default)
RISK_THRESHOLD_ALLOW=30
RISK_THRESHOLD_OTP=60

# Bobot hybrid AI vs rule-based (jumlah harus = 1.0)
AI_RISK_WEIGHT=0.7
RULE_RISK_WEIGHT=0.3

# Path model yang telah dilatih
MODEL_PATH=app/models/isolation_forest.pkl

# Timeout inferensi dalam detik
INFERENCE_TIMEOUT_SECONDS=2.0

# Logging
LOG_LEVEL=INFO

# Jangan tampilkan detail error ke klien di production
DEBUG_RESPONSES=false
